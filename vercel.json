{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DATABASE_PATH": "/tmp/database.json",
    "ENVIRONMENT": "production",
    "DEBUG": "false",
    "FRONTEND_URL": "https://ai-assistant-healthcare-web.vercel.app",
    "FRONTEND_ORIGIN_REGEX": "https://.*\\.vercel\\.app"
  }
}
